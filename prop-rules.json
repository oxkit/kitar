    "meta":  {
                 "version":  2,
                 "updated":  "2026-07-07",
                 "purpose":  "Reusable prop-firm rule parameters. The UI should render all challenge accounts with one challenge template and all sim-funded accounts with one sim-funded template.",
                 "standardRuleFields":  {
                                            "start":  "Tracker/account starting balance; records-based sim-funded accounts may start at 0",
                                            "target":  "Profit target",
                                            "dd":  "Maximum drawdown amount",
                                            "ddType":  "Drawdown mode, for example EOD, static, or intraday",
                                            "consistencyPct":  "Consistency rule as a decimal percentage",
                                            "consistencyCapDay":  "Fixed best-day cap when the rule is dollar based",
                                            "minDays":  "Minimum trading days",
                                            "renewalDate":  "Account-specific renewal date, not part of the reusable template",
                                            "accountSize":  "Nominal prop account size, when different from tracker starting balance"
                                        },
                 "notes":  [
                               "Product presets should only provide parameters for the shared challenge or sim-funded template.",
                               "Renewal dates are account-specific and should be calculated from the purchase/start date unless the user says otherwise.",
                               "Payout rules marked confirmWithUser are inferred from existing dashboard data and should be verified before automation depends on them."
                           ]
             },
